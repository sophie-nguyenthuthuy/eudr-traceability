# Application
APP_ENV=local
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-string-in-prod

# Database
DATABASE_URL=postgresql+asyncpg://eudr:eudr@postgres:5432/eudr
DATABASE_URL_SYNC=postgresql://eudr:eudr@postgres:5432/eudr
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Auth (RS256). Generate with: openssl genrsa -out jwt-private.pem 2048
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt-private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt-public.pem
JWT_ISSUER=eudr-traceability
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=2592000

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# S3 / MinIO
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_DOCUMENTS=eudr-documents
S3_BUCKET_DDS=eudr-dds-payloads

# EU TRACES NT
TRACES_NT_ENV=sandbox
TRACES_NT_BASE_URL=https://webgate.training.ec.europa.eu/tracesnt-api
TRACES_NT_CLIENT_ID=
TRACES_NT_CLIENT_SECRET=

# Deforestation data sources
HANSEN_GFC_RASTER_URL=s3://eudr-public-data/hansen-gfc/lossyear-2023.tif
JRC_TMF_RASTER_URL=s3://eudr-public-data/jrc-tmf/deforestation-2023.tif
EUDR_CUTOFF_DATE=2020-12-31

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_METRICS_ENABLED=true
